// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Transaction {
  id        String           @id @default(uuid())
  date      DateTime
  name      String
  type      TransactionType
  amount    Decimal
  category  String
  account   String
  note      String?
  createdAt DateTime         @default(now())
}

model MonthlyExpenseAnalysis {
  id        String   @id @default(uuid())
  month     String   // YYYY-MM
  type      String   // 目前固定为 "expense"，预留扩展空间
  content   String   // AI 分析结果原文（JSON 或 Markdown 文本）
  createdAt DateTime @default(now())
}

model ExpenseCategory {
  id        String   @id @default(uuid())
  name      String   @unique
  color     String
  icon      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model IncomeCategory {
  id        String   @id @default(uuid())
  name      String   @unique
  color     String
  icon      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PaymentMethod {
  id        String   @id @default(uuid())
  name      String   @unique
  color     String
  icon      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  importChannelPayments ImportChannelPayment[]
}

// AI 记账导入类型（channel）与「无法从账单判定时」的默认支付方式（须为 PaymentMethod 之一）
model ImportChannelPayment {
  channel         String        @id
  paymentMethodId String
  paymentMethod   PaymentMethod @relation(fields: [paymentMethodId], references: [id], onDelete: Restrict)
}

// 可在「管理员」面板中编辑的 AI 系统提示词；未写入数据库时使用代码内默认模板。
model AiPrompt {
  id        String   @id @default(uuid())
  key       String   @unique
  content   String
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

// 每次成功保存提示词后的内容快照，用于在面板中回滚到历史版本（每 key 仅保留最近若干条）。
model AiPromptVersion {
  id        String   @id @default(uuid())
  promptKey String
  content   String
  createdAt DateTime @default(now())

  @@index([promptKey])
}

// 分类规则：记录商户名 → 类目的映射，用于 AI 导入时自动分类，避免反复手动确认。
model CategoryRule {
  id           String          @id @default(uuid())
  type         TransactionType
  merchantName String          // 要匹配的商户名（精确匹配，大小写不敏感）
  category     String          // 目标分类名
  source       String          @default("learned") // "learned"（从历史学习）或 "manual"（手动创建）
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@unique([type, merchantName])
}

enum TransactionType {
  income
  expense
}
