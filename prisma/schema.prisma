// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Transaction {
  id        String           @id @default(uuid())
  date      DateTime
  name      String
  type      TransactionType
  amount    Decimal
  category  String
  account   String
  note      String?
  createdAt DateTime         @default(now())
}

model MonthlyExpenseAnalysis {
  id        String   @id @default(uuid())
  month     String   // YYYY-MM
  type      String   // 目前固定为 "expense"，预留扩展空间
  content   String   // AI 分析结果原文（JSON 或 Markdown 文本）
  createdAt DateTime @default(now())
}

model ExpenseCategory {
  id        String   @id @default(uuid())
  name      String   @unique
  color     String
  icon      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model IncomeCategory {
  id        String   @id @default(uuid())
  name      String   @unique
  color     String
  icon      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PaymentMethod {
  id        String   @id @default(uuid())
  name      String   @unique
  color     String
  icon      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  importChannelPayments ImportChannelPayment[]
}

// AI 记账导入类型（channel）与「无法从账单判定时」的默认支付方式（须为 PaymentMethod 之一）
model ImportChannelPayment {
  channel         String        @id
  paymentMethodId String
  paymentMethod   PaymentMethod @relation(fields: [paymentMethodId], references: [id], onDelete: Restrict)
}

// 可在「管理员」面板中编辑的 AI 系统提示词；未写入数据库时使用代码内默认模板。
model AiPrompt {
  id        String   @id @default(uuid())
  key       String   @unique
  content   String
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

enum TransactionType {
  income
  expense
}
